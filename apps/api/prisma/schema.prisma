generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SaveParseStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum StorageProvider {
  LOCAL
  SUPABASE
  S3
}

enum SupportedGame {
  RUBY
  SAPPHIRE
  EMERALD
  FIRERED
  LEAFGREEN
}

enum PokemonType {
  NORMAL
  FIRE
  WATER
  ELECTRIC
  GRASS
  ICE
  FIGHTING
  POISON
  GROUND
  FLYING
  PSYCHIC
  BUG
  ROCK
  GHOST
  DRAGON
  DARK
  STEEL
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  username     String        @unique
  emailVerified Boolean      @default(false)
  image        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  accounts     Account[]
  saveProfiles SaveProfile[]
  saveUploads  SaveUpload[]
  sessions     Session[]
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String   @id @default(cuid())
  identifier String   @unique
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SaveProfile {
  id          String                @id @default(cuid())
  userId      String
  name        String
  game        SupportedGame?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  saveUploads SaveUpload[]
  dexEntries  SaveProfileDexEntry[]    @relation("SaveProfileDexEntries")
  dexOverrides SaveProfileDexOverride[] @relation("SaveProfileDexOverrides")

  @@unique([userId, name])
}

model SaveUpload {
  id               String          @id @default(cuid())
  userId           String
  saveProfileId    String
  originalFilename String
  storageProvider  StorageProvider
  storageKey       String
  fileUrl          String?
  fileSizeBytes    Int
  parseStatus      SaveParseStatus @default(PENDING)
  detectedGame     SupportedGame?
  parseError       String?
  trainerName      String?
  trainerGender    String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  saveProfile SaveProfile @relation(fields: [saveProfileId], references: [id], onDelete: Cascade)
}

model PokemonSpecies {
  id          Int                   @id
  dexNumber   Int                   @unique
  name        String
  generation  Int
  primaryType PokemonType
  secondaryType PokemonType?
  isAvailable Boolean               @default(true)
  dexEntries  SaveProfileDexEntry[]    @relation("SaveProfileDexEntries")
  dexOverrides SaveProfileDexOverride[] @relation("SaveProfileDexOverrides")
}

model SaveProfileDexEntry {
  id               String   @id @default(cuid())
  saveProfileId    String
  pokemonSpeciesId Int
  seen             Boolean  @default(false)
  caught           Boolean  @default(false)
  hasLivingEntry   Boolean  @default(false)
  // shinySeen stores imported shiny seen state for one species snapshot row.
  shinySeen        Boolean  @default(false)
  // shinyCaught stores imported shiny caught state for one species snapshot row.
  shinyCaught      Boolean  @default(false)
  // shinyLiving stores imported shiny living state for one species snapshot row.
  shinyLiving      Boolean  @default(false)
  // totalOwnedCount stores the imported non-shiny-plus-shiny ownership count for one species snapshot row.
  totalOwnedCount  Int      @default(0)
  // shinyOwnedCount stores the imported shiny ownership count for one species snapshot row.
  shinyOwnedCount  Int      @default(0)
  updatedAt        DateTime @updatedAt

  saveProfile    SaveProfile    @relation("SaveProfileDexEntries", fields: [saveProfileId], references: [id], onDelete: Cascade)
  pokemonSpecies PokemonSpecies @relation("SaveProfileDexEntries", fields: [pokemonSpeciesId], references: [id], onDelete: Cascade)

  @@unique([saveProfileId, pokemonSpeciesId])
}

model SaveProfileDexOverride {
  id               String   @id @default(cuid())
  saveProfileId    String
  pokemonSpeciesId Int
  seen             Boolean?
  caught           Boolean?
  hasLivingEntry   Boolean?
  // shinySeen stores one nullable manual shiny seen override for a species row.
  shinySeen        Boolean?
  // shinyCaught stores one nullable manual shiny caught override for a species row.
  shinyCaught      Boolean?
  // shinyLiving stores one nullable manual shiny living override for a species row.
  shinyLiving      Boolean?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  saveProfile    SaveProfile    @relation("SaveProfileDexOverrides", fields: [saveProfileId], references: [id], onDelete: Cascade)
  pokemonSpecies PokemonSpecies @relation("SaveProfileDexOverrides", fields: [pokemonSpeciesId], references: [id], onDelete: Cascade)

  @@unique([saveProfileId, pokemonSpeciesId])
}
